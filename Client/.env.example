# FASTag India Frontend Environment Variables
# Copy this file to .env and update with your actual values

# API Configuration
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_URL=http://localhost:3000

# App Configuration
REACT_APP_VERSION=1.0.0

# Payment Gateway
REACT_APP_RAZORPAY_KEY_ID=your_razorpay_key_id_here

# Feature Flags
REACT_APP_ENABLE_OTP_LOGIN=true
REACT_APP_ENABLE_ADMIN_PANEL=true
REACT_APP_ENABLE_2FA=true

# API Configuration
REACT_APP_API_TIMEOUT=10000
REACT_APP_API_RETRY_COUNT=3

# File Upload Configuration
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,application/pdf

# Session Configuration
REACT_APP_SESSION_TIMEOUT=900000
REACT_APP_REFRESH_TOKEN_BUFFER=60000

# Debug Configuration (set to false in production)
REACT_APP_ENABLE_API_LOGGING=true
REACT_APP_ENABLE_REDUX_DEVTOOLS=true

# Environment
NODE_ENV=development